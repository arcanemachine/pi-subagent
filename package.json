{
  "name": "pi-subagent",
  "version": "1.0.0",
  "description": "Pi extension for spawning sub-agents via RPC for parallel task execution",
  "type": "module",
  "keywords": [
    "pi-package"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write src/index.ts README.md"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "^0.72.1",
    "@types/node": "^25.3.3",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*"
  },
  "peerDependenciesMeta": {
    "@mariozechner/pi-coding-agent": {
      "optional": true
    }
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ]
}
